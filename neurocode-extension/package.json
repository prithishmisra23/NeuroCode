{
  "name": "neurocode",
  "displayName": "NeuroCode",
  "description": "AI-powered code intelligence for analysis, visualization, and refactoring.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "NeuroCode.scanRepository",
        "title": "NeuroCode: Scan Repository"
      },
      {
        "command": "NeuroCode.refactorSelection",
        "title": "NeuroCode: Refactor Selection"
      },
      {
        "command": "NeuroCode.predictBugs",
        "title": "NeuroCode: Predict Bugs"
      },
      {
        "command": "NeuroCode.openDashboard",
        "title": "NeuroCode: Open Dashboard"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "@babel/parser": "^7.23.5",
    "@babel/traverse": "^7.23.5",
    "axios": "^1.6.2",
    "cytoscape": "^3.27.0",
    "graphlib": "^2.1.8",
    "openai": "^4.20.1"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.4",
    "@types/cytoscape": "^3.21.0",
    "@types/graphlib": "^2.1.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.x",
    "@types/vscode": "^1.85.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.3.2"
  }
}
